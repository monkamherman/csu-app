# Configuration de l'environnement - TailNext
# Copiez ce fichier en .env.local et modifiez les valeurs

# ==========================================
# Configuration de l'application
# ==========================================

# URL de base de l'application (sans slash final)
NEXT_PUBLIC_APP_URL=https://example.com

# Environnement (development, production, test)
NODE_ENV=production

# Port de l'application (défaut: 3000)
PORT=5000

# ==========================================
# Configuration SEO / Métadonnées
# ==========================================

NEXT_PUBLIC_SITE_NAME="TailNext"
NEXT_PUBLIC_SITE_DESCRIPTION="Un template Next.js + Tailwind CSS"

# ==========================================
# Analytics (optionnel)
# ==========================================

# Google Analytics
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# ==========================================
# Autres intégrations (optionnel)
# ==========================================

# Clés API externes (si nécessaire)
# API_KEY=your_api_key_here

# ==========================================
# Configuration Stripe (Paiement)
# ==========================================

# Clé secrète Stripe (backend)
STRIPE_SECRET_KEY=sk_test_...

# ID du prix du produit Funnel AI
STRIPE_PRICE_ID=price_...
